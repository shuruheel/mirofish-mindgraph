# LLM API Configuration (any OpenAI SDK-compatible API)
# Recommended: Google Gemini 2.5 Flash via OpenRouter
# Note: simulations are token-intensive — start with <40 rounds to estimate cost
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_NAME=google/gemini-2.5-flash

# ===== MindGraph Knowledge Graph Configuration =====
# Register for an API key: https://mindgraph.cloud/dashboard/keys
MINDGRAPH_API_KEY=mg_your_api_key_here
MINDGRAPH_BASE_URL=https://api.mindgraph.cloud

# ===== Summarizer LLM Configuration (Optional) =====
# Non-reasoning model for key info extraction during simulation
# (Reasoning models may waste tokens on <think> tags, producing empty output)
# Uses the same API key and base URL — only configure the model name
# LLM_SUMMARIZER_MODEL=google/gemini-2.5-flash

# ===== Boost LLM Configuration (Optional) =====
# Secondary LLM for performance-critical calls (e.g., report generation)
# If not using boost config, remove these lines entirely
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here
